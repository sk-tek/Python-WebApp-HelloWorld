name: Build and Deploy Cloud Run

on:
  workflow_dispatch:

permissions:
  contents: read

env:
  IMAGE_NAME: webapp

jobs:
  deploy:

    runs-on: ubuntu-latest

    steps:

      - name: Checkout Source
        uses: actions/checkout@v4

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ secrets.GCP_SA_KEY }}

      - name: Setup Google Cloud SDK
        uses: google-github-actions/setup-gcloud@v2

      - name: Set Project
        run: |
          gcloud config set project "${{ vars.GCP_PROJECT_ID }}"

      ####################################################################
      # VALIDATION STAGE
      ####################################################################

      - name: Validate Project Exists
        run: |
          gcloud projects describe "${{ vars.GCP_PROJECT_ID }}"

      - name: Validate Required APIs
        run: |

          REQUIRED_APIS=(
            "run.googleapis.com"
            "artifactregistry.googleapis.com"
          )

          for API in "${REQUIRED_APIS[@]}"
          do
            echo "Checking API: $API"

            until gcloud services list \
              --enabled \
              --filter="config.name=$API" \
              --format="value(config.name)" | grep -q "$API"
            do
              echo "Waiting for API: $API"
              sleep 10
            done

            echo "API Ready: $API"
          done

      - name: Validate Artifact Registry Repository
        run: |

          until gcloud artifacts repositories describe \
            "${{ vars.ARTIFACT_REGISTRY_REPO }}" \
            --location="${{ vars.GCP_REGION }}" \
            >/dev/null 2>&1
          do
            echo "Waiting for Artifact Registry..."
            sleep 10
          done

          echo "Artifact Registry Ready"

      - name: Validate Cloud Run API Access
        run: |
          gcloud run regions list \
            --project="${{ vars.GCP_PROJECT_ID }}" \
            >/dev/null

      ####################################################################
      # BUILD STAGE
      ####################################################################

      - name: Configure Docker Authentication
        run: |
          gcloud auth configure-docker \
            "${{ vars.GCP_REGION }}-docker.pkg.dev" \
            --quiet

      - name: Build Docker Image
        run: |
          docker build \
            -t "${{ vars.GCP_REGION }}-docker.pkg.dev/${{ vars.GCP_PROJECT_ID }}/${{ vars.ARTIFACT_REGISTRY_REPO }}/${{ env.IMAGE_NAME }}:${{ github.sha }}" \
            .

      ####################################################################
      # PUSH STAGE
      ####################################################################

      - name: Push Docker Image
        run: |
          docker push \
            "${{ vars.GCP_REGION }}-docker.pkg.dev/${{ vars.GCP_PROJECT_ID }}/${{ vars.ARTIFACT_REGISTRY_REPO }}/${{ env.IMAGE_NAME }}:${{ github.sha }}"

      ####################################################################
      # DEPLOY STAGE
      ####################################################################

      - name: Deploy Cloud Run
        run: |
          gcloud run deploy \
            "${{ vars.CLOUD_RUN_SERVICE }}" \
            --image="${{ vars.GCP_REGION }}-docker.pkg.dev/${{ vars.GCP_PROJECT_ID }}/${{ vars.ARTIFACT_REGISTRY_REPO }}/${{ env.IMAGE_NAME }}:${{ github.sha }}" \
            --region="${{ vars.GCP_REGION }}" \
            --platform=managed \
            --allow-unauthenticated \
            --quiet

      ####################################################################
      # POST DEPLOY VALIDATION
      ####################################################################

      - name: Get Service URL
        id: service_url
        run: |

          SERVICE_URL=$(gcloud run services describe \
            "${{ vars.CLOUD_RUN_SERVICE }}" \
            --region="${{ vars.GCP_REGION }}" \
            --format='value(status.url)')

          echo "service_url=$SERVICE_URL" >> $GITHUB_OUTPUT

      - name: Validate Service Health
        run: |

          URL="${{ steps.service_url.outputs.service_url }}/health"

          echo "Health Check URL: $URL"

          for i in {1..30}
          do

            STATUS=$(curl -s -o /dev/null -w "%{http_code}" "$URL")

            if [ "$STATUS" = "200" ]; then
              echo "Application Healthy"
              exit 0
            fi

            echo "Waiting for application startup..."
            sleep 10

          done

          echo "Application health check failed"
          exit 1

      - name: Display Service URL
        run: |
          echo ""
          echo "========================================"
          echo "Cloud Run URL"
          echo "${{ steps.service_url.outputs.service_url }}"
          echo "========================================"
